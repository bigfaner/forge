# rust-test justfile recipes
# Used by init-justfile to generate profile-aware justfile targets

# test-e2e: run end-to-end tests (cargo test)
test-e2e feature="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{feature}}" ]; then
        cargo test --test e2e -- --nocapture
    else
        cargo test --test e2e -- {{feature}} --nocapture
    fi

# e2e-setup: verify compilation
e2e-setup force="":
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build
    echo "OK: e2e dependencies ready (rust-test)"

# e2e-verify: check for unresolved // VERIFY: markers
e2e-verify feature="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{feature}}" ]; then
        echo "Usage: just e2e-verify --feature <slug>" >&2
        exit 1
    fi
    if [ ! -d "tests/e2e/features/{{feature}}" ]; then
        echo "Error: tests/e2e/features/{{feature}}/ not found" >&2
        exit 1
    fi
    matches=$(grep -rn '// VERIFY:' "tests/e2e/features/{{feature}}/" --include='*.rs' || true)
    if [ -n "$matches" ]; then
        count=$(echo "$matches" | wc -l | tr -d ' ')
        echo "Error: $count unresolved // VERIFY: marker(s) in tests/e2e/features/{{feature}}/" >&2
        echo "$matches" >&2
        exit 1
    fi
    echo "OK: no unresolved // VERIFY: markers in tests/e2e/features/{{feature}}/"

# e2e-compile: compile-check e2e test files
e2e-compile:
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build --test e2e
    echo "OK: Rust compilation passed"

# e2e-discover: list all e2e test cases without running them
e2e-discover:
    #!/usr/bin/env bash
    set -euo pipefail
    cargo test --test e2e -- --list
