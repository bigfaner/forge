{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Index Schema",
  "description": "Schema for task index file",
  "type": "object",
  "required": ["feature", "prd", "design", "created", "status", "tasks"],
  "properties": {
    "feature": {
      "type": "string"
    },
    "prd": {
      "type": "string"
    },
    "design": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": ["planning", "in-progress", "completed"]
    },
    "statusEnum": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priorityEnum": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "title", "priority", "status", "file"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "estimatedTime": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "blocked", "skipped"] },
          "file": { "type": "string" },
          "record": { "type": "string" }
        }
      }
    },
    "statusEnum": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priorityEnum": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
