# pytest justfile recipes
# Used by init-justfile to generate profile-aware justfile targets

# test-e2e: run end-to-end tests (pytest)
test-e2e feature="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{feature}}" ]; then
        python -m pytest tests/e2e/ -v --tb=short
    else
        python -m pytest "tests/e2e/features/{{feature}}/" -v --tb=short
    fi

# e2e-setup: verify compilation
e2e-setup force="":
    #!/usr/bin/env bash
    set -euo pipefail
    python -m py_compile tests/e2e/ 2>/dev/null || true
    pip install -q pytest 2>/dev/null || pip3 install -q pytest 2>/dev/null || true
    echo "OK: e2e dependencies ready (pytest)"

# e2e-verify: check for unresolved # VERIFY: markers
e2e-verify feature="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "{{feature}}" ]; then
        echo "Usage: just e2e-verify --feature <slug>" >&2
        exit 1
    fi
    if [ ! -d "tests/e2e/features/{{feature}}" ]; then
        echo "Error: tests/e2e/features/{{feature}}/ not found" >&2
        exit 1
    fi
    matches=$(grep -rn '# VERIFY:' "tests/e2e/features/{{feature}}/" --include='*.py' || true)
    if [ -n "$matches" ]; then
        count=$(echo "$matches" | wc -l | tr -d ' ')
        echo "Error: $count unresolved # VERIFY: marker(s) in tests/e2e/features/{{feature}}/" >&2
        echo "$matches" >&2
        exit 1
    fi
    echo "OK: no unresolved # VERIFY: markers in tests/e2e/features/{{feature}}/"

# e2e-compile: syntax-check e2e test files
e2e-compile:
    #!/usr/bin/env bash
    set -euo pipefail
    python -m compileall tests/e2e/ -q
    echo "OK: Python compilation passed"

# e2e-discover: list all e2e test cases without running them
e2e-discover:
    #!/usr/bin/env bash
    set -euo pipefail
    python -m pytest tests/e2e/ --collect-only -q
