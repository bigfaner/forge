{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|clear|compact",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
						"async": false
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
						"async": false
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "forge cleanup"
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "forge cleanup"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "forge quality-gate"
					},
					{
						"type": "command",
						"command": "forge feature complete --if-done"
					}
				]
			}
		]
	}
}
